# DocAI — environment configuration template
#
# Copy to .env.local for development. Production values are configured via
# Vercel project env vars (frontend, route handlers, and Inngest functions
# all run on Vercel) and via the Inngest dashboard for cloud-side knobs.
#
# Never commit .env or .env.local — see root .gitignore.
#
# The defaults, exact spend caps, owner allow-list, and per-deployment
# defensive thresholds live in private operational docs — NOT in this file
# and NOT in the public repo. This template lists variable NAMES with
# placeholder values only.

# ============================================================
# Database & infrastructure
# ============================================================
# Runtime connection — least-privilege docai_app role (no CREATE).
DATABASE_URL=
# Migrations only — Neon owner role (DDL needs CREATE). Falls back to DATABASE_URL.
MIGRATE_DATABASE_URL=
REDIS_URL=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PROJECT_QUOTA_GB=

# ============================================================
# Authentication (Clerk)
# ============================================================
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# ============================================================
# Privileged-account allow-list
# CSV of emails that bypass rate limits while still emitting usage metrics.
# ============================================================
OWNER_EMAILS=

# ============================================================
# Provider API keys
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# ============================================================
# Background jobs — Inngest (see ADR-001)
# EVENT_KEY is sent with events. SIGNING_KEY verifies webhook calls.
# ============================================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============================================================
# Model selection (see ADR-016)
# Format: provider:model_id  (providers: anthropic | openai | deepseek)
# Embeddings/rerank use their own native providers.
# Per-role swapping is intentional — change without redeploying code.
# ============================================================
CHAT_PROD_MODEL=
CHAT_DEV_MODEL=
AGENT_FREE_MODEL=
AGENT_PRO_MODEL=
AGENT_SUBTASK_MODEL=
GATE_PRIMARY_MODEL=
GATE_SANITY_MODEL=
EVAL_JUDGE_MODEL=
EMBEDDINGS_MODEL=
RERANK_MODEL=

# ============================================================
# RAG chat tuning (M3)
# Reranker-score cutoff below which retrieved passages are dropped and the chat
# refuses ("I couldn't find that in your documents") instead of answering from
# weak matches. Optional — a default applies. Calibrated by the M5 eval harness.
# ============================================================
CHAT_RELEVANCE_THRESHOLD=

# ============================================================
# Project budget kill switch (see ADR-015)
# Caps on free-tier spend. BYOK + privileged accounts continue when hit.
# ============================================================
PROJECT_DAILY_BUDGET_USD=
PROJECT_MONTHLY_BUDGET_USD=

# ============================================================
# Observability (Langfuse)
# ============================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=
NODE_ENV=
