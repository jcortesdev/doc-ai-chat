{
  "name": "@doc-ai-chat/db",
  "private": true,
  "version": "0.0.0",
  "description": "Database schema (Drizzle), migrations, and typed client for Neon Postgres + pgvector.",
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./chunker": "./src/chunker.ts",
    "./vector-literal": "./src/vector-literal.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env.local -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../.env.local -- drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
